# VARIABLES DE ENTORNO - Proyecto CI/CD Local
# Copia este archivo como .env y personaliza los valores
# NUNCA commitees el archivo .env al repositorio
# ══════════════════════════════════════════════════════════════════════

# ── Aplicación ────────────────────────────────────────────────────────
APP_VERSION=1.0.0
SECRET_KEY=cambia_esto_por_un_valor_seguro_en_produccion

# ── Grafana ───────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# ── Vault ─────────────────────────────────────────────────────────────
VAULT_TOKEN=dev-root-token
